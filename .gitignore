# Packaging and persistent runtime cache
/build/
/dist/
/src/*.egg-info/
.runtime/
*.sqlite3

# SearXNG live config: a runtime file the container mounts and chowns to its own
# uid. Tracking it causes git-vs-container ownership conflicts, so it's ignored;
# bootstrap from deploy/searxng-settings.yml.example (deploy/update.sh does this).
/searxng/settings.yml

# Local user credential store (password HASHES — never commit, even by mistake).
# Default lives under .runtime/ (already ignored) but pin the filename anywhere it lands.
users.json
**/users.json
users.json.tmp
**/users.json.tmp

# Untracked junk archive (moved-aside legacy files)
archive/

# Local model weights and generated artifacts
# (name-only patterns below also match files now living under archive/ and docs/archive/)
student_model_lora/
fine_tuning/student_model_lora/
*.safetensors
*.bin
UK_Rent_Agent_Technical_Report.*
quick_test_results.csv
diagnose_geocoding.py
**/.env

# Zoopla repair guide (local only)
ZOOPLA_REPAIR_GUIDE.md

# Next-gen architecture design doc (local only)
NEXT_GEN_AGENT_ARCHITECTURE.md

# Fine-tuning datasets (regenerable via fine_tuning/generate_data.py).
# The LoRA weights dir (fine_tuning/student_model_lora/) is already ignored above.
fine_tuning/train.jsonl
fine_tuning/val.jsonl
fine_tuning/test.jsonl
fine_tuning/dataset_raw.json

# Frozen one-off evaluation run artifacts (large events/raw-run streams + CSVs).
# Small summary/report files (*.json, *.md, .gitkeep) under evaluation/results/
# stay tracked as provenance; only the bulky run streams are ignored.
evaluation/results/**/*.jsonl
evaluation/results/**/*.csv

# Local schema-compaction measurement package; intentionally never committed.
# The evaluation/results/**/*.jsonl|csv rules deliberately keep *.json/*.md tracked as
# provenance, so this directory needs its own exact rule or `git add -A` sweeps it in.
/evaluation/results/schema_compaction_ab_2026-07-22/
