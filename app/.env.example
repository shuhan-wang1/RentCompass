# Copy this file to .env and fill in your real values. .env is gitignored.

# --- LLM provider -------------------------------------------------------------
# 'deepseek' (cloud, OpenAI-compatible) or 'ollama' (local)
LLM_PROVIDER="deepseek"

# DeepSeek API (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma3:27b-cloud"

# --- Maps / geo (now FREE: Nominatim/Postcodes.io + TfL + Overpass; no Google needed) ---
# Optional: a free TfL app key (https://api-portal.tfl.gov.uk) raises rate limits.
# TfL Journey Planner also works without it at low volume.
TFL_APP_KEY=""
# (legacy, no longer used by the app)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"
OPENROUTESERVICE_API_KEY="your_openrouteservice_api_key_here"

# --- Optional -----------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"
