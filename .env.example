# Root-level environment for docker-compose variable substitution.
# Copy this file to .env (which is gitignored) and fill in real values.
#
# NOTE: this is Compose's own env file (same directory as docker-compose.yml),
# used for ${VAR} substitution INSIDE docker-compose.yml. It is separate from
# app/.env, which is bind-mounted into the app container (see the `app` service
# env_file). App/LLM secrets live in app/.env; compose-substitution secrets live
# here.

# SearXNG server.secret_key. Required — the stack refuses to start without it.
# Generate a fresh 64-hex value:  openssl rand -hex 32
SEARXNG_SECRET="replace_me_with_openssl_rand_hex_32"

# --- Canary fc pool (only needed for the `canary` profile) --------------------
# Consumed by the app-fc service in docker-compose.yml. Both are required to
# bring up the fc pool (`docker compose --profile canary up -d app-fc`) and are
# ignored by the default legacy-only stack.
#
# FC_CANARY_IMAGE: the IMMUTABLE, pre-built candidate image tag the fc pool runs
# (never :latest, never rebuilt from the tree). Build it out of band from the
# candidate tag — see docs/canary_runbook.md "Image build".
# FC_CANARY_SHA: the candidate commit sha; surfaced in X-Agent-Version and
# per-turn telemetry. Must match the sha the image was built from.
# FC_CANARY_IMAGE="uk-rent-agent:canary-fc-loop-<sha>"
# FC_CANARY_SHA="<sha>"
