# Keep the build context small and secrets/data out of image layers.
# Runtime data + secrets are bind-mounted from the host at run time instead.

# Virtualenvs (huge — must never enter the context)
**/.venv
**/venv
**/env

# VCS / caches / bytecode
.git
.gitignore
**/__pycache__
**/*.pyc
**/*.pyo

# Secrets — mounted at runtime, never baked into the image
**/.env
**/.env.*
.env

# Runtime state / generated data — bind-mounted from host
.runtime/
**/*.sqlite3
chroma_db/
chroma_db_area/
chroma_db_agent_memory/
app/chroma_db/
app/chroma_db_area/
app/chroma_db_agent_memory/
app/data/
**/*.log

# Docker + local model weights + heavy dirs not needed to run the web app
Dockerfile
docker-compose.yml
.dockerignore
searxng/
*.safetensors
*.bin
fine_tuning/
evals/
tests/
tests_refactor/
scrapped_data/
archive/
docs/archive/
.playwright-mcp/
*.md
