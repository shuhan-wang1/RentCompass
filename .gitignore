# SearXNG live config: a runtime file the container mounts and chowns to its own
# uid. Tracking it causes git-vs-container ownership conflicts, so it's ignored;
# bootstrap from deploy/searxng-settings.yml.example (deploy/update.sh does this).
/searxng/settings.yml

